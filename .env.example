# VoiceType v2.0 Environment Configuration

# Application Settings
VOICE_TYPE_HOTKEY=Alt+V
VOICE_TYPE_MODEL_SIZE=small
VOICE_TYPE_CLIPBOARD_PROTECTION=true

# Whisper Model Settings
# Options: tiny, base, small, medium, large
WHISPER_MODEL=small
WHISPER_DEVICE=cpu  # Options: cpu, cuda, mps
WHISPER_LANGUAGE=en

# Audio Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1024

# Logging
LOG_LEVEL=INFO
LOG_FILE=voice_type.log

# Optional: API keys for cloud services (if using cloud STT)
# OPENAI_API_KEY=your_key_here
# AZURE_SPEECH_KEY=your_key_here
